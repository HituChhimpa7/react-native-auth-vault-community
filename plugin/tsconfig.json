{
  "compilerOptions": {
    "outDir": "build",
    "rootDir": "src",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["build", "node_modules"]
}
